APP_NAME=KijoV2
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.amiosh.com
PUBLIC_STORAGE_URL=https://kijo.amiosh.com/storage

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=daily
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=amioshc1_kijo_07_2025
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=43200
SESSION_EXPIRE_ON_CLOSE=false
SESSION_ENCRYPT=true
SESSION_HTTP_ONLY=true
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=smtp
MAIL_SCHEME=ssl
MAIL_HOST=work.amiosh.com
MAIL_PORT=465
MAIL_USERNAME=kijo@work.amiosh.com
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="kijo@work.amiosh.com"
MAIL_FROM_NAME="Kijo Alert"

# Dedicated sender for CRM quotation emails.
QUOTE_MAIL_MAILER=quote_smtp
QUOTE_MAIL_SCHEME=ssl
QUOTE_MAIL_HOST=work.amiosh.com
QUOTE_MAIL_PORT=465
QUOTE_MAIL_USERNAME=info.admin@amiosh.com
QUOTE_MAIL_PASSWORD=
QUOTE_MAIL_FROM_ADDRESS="info.admin@amiosh.com"
QUOTE_MAIL_FROM_NAME="AMIOSH Admin"

# Default onboarding password checked by the weekly security cron.
KIJO_DEFAULT_PASSWORD=
# Fallback admin email for default-password alerts when no admin role is found in system_users.
KIJO_FALLBACK_ADMIN_EMAIL=

# Google Places API key. Restrict by IP and API in Google Cloud Console.
GOOGLE_PLACES_API_KEY=

VITE_APP_NAME="${APP_NAME}"
