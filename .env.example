APP_NAME=KijoV2
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_FRONTEND_URL=http://localhost:3000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

GOOGLE_TRANSLATE_API_KEY=
TRANSLATION_PROVIDER=google
TRANSLATION_SOURCE=en
TRANSLATION_TARGET=ms

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=daily
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=kijoappdb
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=43200
SESSION_EXPIRE_ON_CLOSE=false
SESSION_ENCRYPT=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=smtp
MAIL_SCHEME=smtps
MAIL_HOST=work.amiosh.com
MAIL_PORT=465
MAIL_USERNAME=kijo@work.amiosh.com
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="kijo@work.amiosh.com"
MAIL_FROM_NAME="Kijo Alert"
LEAVE_APPLICATION_MAIL_TO=

# Dedicated sender for CRM quotation emails.
QUOTE_MAIL_MAILER=quote_smtp
QUOTE_MAIL_SCHEME=smtps
QUOTE_MAIL_HOST=work.amiosh.com
QUOTE_MAIL_PORT=465
QUOTE_MAIL_USERNAME=info.admin@amiosh.com
QUOTE_MAIL_PASSWORD=
QUOTE_MAIL_FROM_ADDRESS="info.admin@amiosh.com"
QUOTE_MAIL_FROM_NAME="AMIOSH Admin"

# Default onboarding password checked by the weekly security cron
KIJO_DEFAULT_PASSWORD=
# Fallback admin email for default-password alerts when no admin role is found in system_users
KIJO_FALLBACK_ADMIN_EMAIL=

# Google Places API key — restrict by IP + API in Google Cloud Console
GOOGLE_PLACES_API_KEY=

WORKLOAD_AI_CLASSIFICATION_ENABLED=false
OPENAI_API_KEY=
WORKLOAD_AI_CLASSIFICATION_MODEL=gpt-5-nano
WORKLOAD_AI_CLASSIFICATION_TIMEOUT_MS=30000

VITE_APP_NAME="${APP_NAME}"
